# ===========================
# SITE
# ===========================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Ma Boutique

# ===========================
# STRAPI
# ===========================
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=votre-token-de-dev
STRAPI_WRITE_API_TOKEN=votre-token-write-de-dev
STRAPI_PREVIEW_TOKEN=votre-preview-token

# Preview / Drafts
PREVIEW_SECRET=changeme
USE_DRAFT_MODE=false

# ===========================
# STRIPE
# ===========================
# Clés de test disponibles sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — obtenu avec `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# En production : créer un webhook dans le dashboard Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================
# CONTACT FORM (optionnel)
# ===========================
# COMPANY_NAME="Ma Boutique"
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=contact@mail.votre-domaine.com
# CONTACT_EMAIL=destinataire@email.com

# ===========================
# ISR (optionnel)
# ===========================
# REVALIDATE_SECRET=changeme

# ===========================
# PRODUCTION — décommenter et adapter
# ===========================
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.com
# NEXT_PUBLIC_STRAPI_URL=https://strapi.up.railway.app
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
