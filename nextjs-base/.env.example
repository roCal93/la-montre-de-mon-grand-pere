# ===========================
# SITE
# ===========================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Ma Boutique

# ===========================
# STRAPI
# ===========================
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=votre-token-de-dev
STRAPI_WRITE_API_TOKEN=votre-token-write-de-dev
STRAPI_PREVIEW_TOKEN=votre-preview-token

# Preview / Drafts
# Générer avec : openssl rand -hex 32
PREVIEW_SECRET=changeme
USE_DRAFT_MODE=false

# ===========================
# STRIPE
# ===========================
# Clés de test disponibles sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — obtenu avec `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# En production : créer un webhook dans le dashboard Stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Collection Strapi optionnelle pour persister les erreurs webhook
# STRAPI_WEBHOOK_ERROR_COLLECTION=webhook-errors

# ===========================
# CONTACT FORM (optionnel)
# ===========================
# COMPANY_NAME="Ma Boutique"
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=contact@mail.votre-domaine.com
# CONTACT_EMAIL=destinataire@email.com

# ===========================
# AUTH
# ===========================
# Requis par NextAuth — générer avec : openssl rand -hex 32
AUTH_SECRET=
# Secret HMAC des QR de claim montre (par défaut fallback sur AUTH_SECRET)
CLAIM_QR_SECRET=
# URL de base utilisée pour générer les liens de claim (sinon NEXT_PUBLIC_SITE_URL)
CLAIM_QR_BASE_URL=http://localhost:3000
# Secret partagé avec Strapi pour sécuriser l'endpoint assign-customer
CLAIM_ASSIGN_SECRET=
# URL publique canonique du front (mettre le domaine prod sur Vercel)
NEXTAUTH_URL=http://localhost:3000
# Requis derrière proxy (Vercel, Railway, etc.)
AUTH_TRUST_HOST=true

# ===========================
# RATE LIMITING (requis en production)
# ===========================
# Créer un compte sur https://upstash.com → Redis → REST API
# Sans ces variables, le rate limiting ne fonctionne pas sur Vercel (serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================
# ISR (optionnel)
# ===========================
# Générer avec : openssl rand -hex 32
REVALIDATE_SECRET=changeme

# ===========================
# PRODUCTION — décommenter et adapter
# ===========================
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.com
# NEXT_PUBLIC_STRAPI_URL=https://strapi.up.railway.app
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
