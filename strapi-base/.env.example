# Server
HOST=localhost
PORT=1337
NODE_ENV=development

# Secrets
APP_KEYS=changeme1,changeme2
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
ENCRYPTION_KEY=changeme
JWT_SECRET=changeme

# Database (SQLite par défaut pour dev)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Pour PostgreSQL en production :
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

# Preview integration
CLIENT_URL=http://localhost:3000
PREVIEW_SECRET=changeme
ALLOWED_ORIGINS=http://localhost:3000,https://ton-site.com
# Example production value:
# ALLOWED_ORIGINS=https://monsite.com,https://www.monsite.com

# Nom du projet Vercel (pour restreindre le CORS aux previews de CE projet uniquement)
# Doit correspondre au nom du projet dans .vercel/project.json (valeur "projectName")
VERCEL_PROJECT_NAME=nextjs-base

# Cloudinary (production) — RECOMMENDED: set a single CLOUDINARY_URL
# Ex: CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# OR provide the individual vars below (not recommended in prod):
# CLOUDINARY_NAME=your_cloud
# CLOUDINARY_KEY=your_key
# CLOUDINARY_SECRET=your_secret

# Stripe — for product/price synchronization
# Get your key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_changeme
