{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer orders placed via Stripe Checkout"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "stripeSessionId": {
      "type": "string",
      "unique": true,
      "private": true
    },
    "stripePaymentIntentId": {
      "type": "string",
      "private": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "shipped", "cancelled", "refunded"],
      "default": "pending",
      "required": true
    },
    "customerEmail": {
      "type": "email",
      "required": true
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "lineItems": {
      "type": "component",
      "component": "shop.order-line-item",
      "repeatable": true,
      "required": true,
      "min": 1
    },
    "shippingAddress": {
      "type": "component",
      "component": "shop.shipping-address",
      "repeatable": false,
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "shippingCost": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "total": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "currency": {
      "type": "string",
      "default": "eur",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "locale": {
      "type": "string",
      "default": "fr"
    }
  }
}
